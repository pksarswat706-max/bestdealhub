<div class="product-info">
<h3>Wireless Earbuds</h3>
<div class="price">₹1,999</div>
<div class="old-price">₹3,999</div>

<a href="#" class="amazon-btn">Amazon Deal</a>
<a href="#" class="flipkart-btn">Flipkart Deal</a>
</div>
</div>

</section>
<style>

.deal-day{
background:#081b3a;
color:white;
padding:70px 5%;
text-align:center;
}

.deal-day h2{
font-size:42px;
margin-bottom:20px;
}

.deal-day p{
font-size:18px;
max-width:700px;
margin:auto;
line-height:1.8;
}

.info-section{
padding:70px 5%;
background:white;
}

.info-box{
max-width:1000px;
margin:auto;
