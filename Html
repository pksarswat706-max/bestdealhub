.info-box p{
line-height:1.8;
color:#444;
}

footer{
background:#081b3a;
color:white;
padding:40px 5%;
text-align:center;
}

.footer-links a{
color:#ffb400;
text-decoration:none;
margin:0 10px;
}

.footer-links{
margin-bottom:20px;
}

