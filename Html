exclusive rewards.
</p>

<a href="#products" class="btn">Explore Deals</a>

</div>

<div class="hero-image">
<img src="https://images.unsplash.com/photo-1546868871-7041f2a55e12?w=1000">
</div>

</div>

</section>
<style>

.categories{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
padding:0 5% 60px;
}

.category{
background:white;
padding:25px;
border-radius:15px;
text-align:center;
box-shadow:0 4px 15px rgba(0,0,0,.08);
font-weight:bold;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
padding:0 5% 70px;
}

.product-card{
background:white;
border-radius:15px;
overflow:hidden;
box-shadow:0 4px 15px rgba(0,0,0,.08);
}

.product-card img{
width:100%;
height:220px;
object-fit:cover;
}

.product-info{
padding:20px;
}

.product-info h3{
margin-bottom:10px;
}

.price{
font-size:28px;
font-weight:bold;
color:green;
margin:10px 0;
}

.old-price{
text-decoration:line-through;
color:#888;
font-size:16px;
}

.amazon-btn,
.flipkart-btn{
display:block;
text-align:center;
padding:12px;
border-radius:8px;
text-decoration:none;
font-weight:bold;
margin-top:10px;
}

.amazon-btn{
background:#ff9900;
color:black;
}

.flipkart-btn{
background:#2874f0;
color:white;
}

